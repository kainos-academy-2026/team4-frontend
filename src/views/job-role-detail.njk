<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Job Role Detail</title>
		<link rel="icon" type="image/png" href="/images/favicon.png" />
		<link rel="stylesheet" href="/styles/branding.css" />
	</head>
	<body class="kainos-page" data-page="job-role-detail" data-page="job-role-detail">
		<header class="kainos-header kainos-header--with-actions kainos-header--with-actions" aria-label="Kainos brand banner">
			<a href="/"><a href="/"><img
				class="kainos-logo"
				src="/images/kainoslogo.png"
				alt="Kainos home"
			/></a>
			<nav class="kainos-header-actions" aria-label="Authentication actions" data-auth-action>
				<a class="kainos-header-link" href="/login">Log in</a>
			</nav>
		</header>

		<main class="page">
			<nav class="kainos-page-nav" aria-label="Breadcrumb">
				<a class="kainos-secondary-action" href="/#roles">Job roles</a>
				{% if jobRole %}
				<span class="kainos-breadcrumb-sep" aria-hidden="true">›</span>
				<span class="kainos-breadcrumb-current">{{ jobRole.roleName }}</span>
				{% endif %}
			</nav>

			{% if jobRole %}
			<h1>{{ jobRole.roleName }}</h1>
			<p class="subtitle">Review the role details and continue to apply.</p>

			<section class="empty-state" aria-label="Job role detail">
				<p><strong>Location:</strong> {{ jobRole.location }}</p>
				<p><strong>Capability:</strong> {{ jobRole.capability }}</p>
				<p><strong>Band:</strong> {{ jobRole.band }}</p>
				<p>
					<strong>Closing Date:</strong>
					{{ jobRole.closingDate.toLocaleDateString('en-GB', { year: '2-digit', month: '2-digit', day: '2-digit' }) }}
				</p>
				<p>
					<strong>Status:</strong>
					<span class="badge{% if jobRole.status | lower == 'closed' %} badge--closed{% elif jobRole.status | lower == 'in progress' %} badge--in-progress{% endif %}" data-role-status-badge>
						{{ jobRole.status }}
					</span>
				</p>
				<p><strong>Open Positions:</strong> {{ jobRole.numberOfOpenPositions }}</p>
				<h2>Description</h2>
				<p>{{ jobRole.description }}</p>
				<h2>Responsibilities</h2>
				<p>{{ jobRole.responsibilities }}</p>
				{% if showApplyForRole %}
				<section class="empty-state" aria-label="Apply for this role" data-apply-section data-job-role-id="{{ jobRole.id }}">
					<h2>Apply for this role</h2>
					<p>Applicants can upload a CV and start an application.</p>
					<div class="alert alert-info" data-login-prompt hidden>
						You must <a href="/login?returnTo=/job-roles/{{ jobRole.id }}/apply">log in</a> to apply for this role.
					</div>
					<div class="alert alert-info" data-application-status hidden aria-live="polite"></div>
					<p>
						<a
							class="kainos-primary-action"
							href="/job-roles/{{ jobRole.id }}/apply"
							data-apply-now
						>
							Apply now
						</a>
					</p>
				</section>
				{% endif %}
				{% if showApplyForRole %}
				<section class="empty-state" aria-label="Apply for this role">
					<h2>Apply for this role</h2>
					<p>Applicants can upload a CV and start an application.</p>
					<a
						class="kainos-primary-action"
						href="/job-roles/{{ jobRole.id }}/apply"
					>
						Apply now
					</a>
				</section>
				{% endif %}
				<p>
					<a class="kainos-primary-action" href="{{ jobRole.sharepointUrl }}">
						Apply on SharePoint
					</a>
				</p>
			</section>
			{% else %}
			<h1>Job Role Detail</h1>
			<p class="subtitle">View more information about an open role.</p>

			{% if errorMessage %}
			<div class="alert alert-error" role="alert">{{ errorMessage }}</div>
			{% endif %}
			{% endif %}
		</main>

		<footer class="kainos-footer" aria-label="Contact information">
			<p>Email: <a href="mailto:careers@kainosjobs.example">careers@kainosjobs.example</a></p>
			<p>Phone: <a href="tel:+442890000000">+44 28 9000 0000</a></p>
		</footer>
		<script src="/scripts/job-application.js"></script>
	</body>
</html>
