<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Apply for Job Role</title>
		<link rel="icon" type="image/png" href="/images/favicon.png" />
		<link rel="stylesheet" href="/styles/branding.css" />
	</head>
	<body class="kainos-page" data-page="job-application">
		<header class="kainos-header" aria-label="Kainos brand banner">
			<img
				class="kainos-logo"
				src="/images/kainoslogo.png"
				alt="Kainos logo"
			/>
		</header>

		<main class="page">
			<a class="kainos-primary-action" href="/job-roles">Back to job roles</a>

			{% if jobRole %}
			<h1>Apply: {{ jobRole.roleName }}</h1>
			<p class="subtitle">Upload your CV to register interest for this role.</p>

			{% if errorMessage %}
			<div class="alert alert-error" role="alert">{{ errorMessage }}</div>
			{% endif %}

			{% if canApply %}
			<form
				class="kainos-auth-card"
				data-job-application-form
				data-job-role-id="{{ jobRole.id }}"
				enctype="multipart/form-data"
			>
				<label class="kainos-field" for="cvFile">
					<span>CV Upload</span>
					<input
						id="cvFile"
						type="file"
						name="cvFile"
						accept=".pdf,.doc,.docx"
						required
						data-cv-file-input
					/>
				</label>
				<p class="kainos-form-error" data-application-error aria-live="polite" hidden></p>
				<button class="kainos-primary-action" type="submit" data-submit-application>
					Submit application
				</button>
			</form>

			<section class="empty-state" data-application-confirmation hidden aria-live="polite">
				<h2>Application submitted</h2>
				<p data-application-confirmation-text></p>
			</section>
			{% endif %}
			{% else %}
			<h1>Apply for Job Role</h1>
			<p class="subtitle">Upload your CV to start your application.</p>

			{% if errorMessage %}
			<div class="alert alert-error" role="alert">{{ errorMessage }}</div>
			{% endif %}
			{% endif %}
		</main>

		<footer class="kainos-footer" aria-label="Contact information">
			<p>Email: <a href="mailto:careers@kainosjobs.example">careers@kainosjobs.example</a></p>
			<p>Phone: <a href="tel:+442890000000">+44 28 9000 0000</a></p>
		</footer>
		<script src="/scripts/job-application.js"></script>
	</body>
</html>