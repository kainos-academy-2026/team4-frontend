<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kainos | Home</title>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="stylesheet" href="/styles/branding.css" />
    <script src="/scripts/auth-session.js" defer></script>
  </head>
  <body class="kainos-page">
    <header class="kainos-header" aria-label="Kainos brand banner">
      <img
        class="kainos-logo"
        src="/images/kainoslogo.png"
        alt="Kainos logo"
      />
      <nav class="kainos-navbar" aria-label="Primary navigation">
        <a class="kainos-nav-link" href="/login" data-auth-signed-out-link>Log in</a>
        <span class="kainos-auth-email" data-auth-signed-in-state hidden data-session-email-note></span>
        <button class="kainos-nav-link kainos-nav-button" type="button" data-logout-action hidden>
          Log out
        </button>
      </nav>
    </header>

    <main class="kainos-hero" aria-label="Home">
      <h1>Hello World</h1>
    </main>

    <footer class="kainos-footer" aria-label="Contact information">
      <p>Contact: support@kainos.com</p>
      <p>Phone: +44 28 9089 0000</p>
    </footer>
  </body>
</html>
