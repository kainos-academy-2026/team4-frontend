{
	"name": "team4-frontend",
	"version": "1.0.0",
	"description": "Team4 Frontend",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.json && cp -r src/views dist/views && cp -r public dist/public",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kainos-academy-2026/team4-frontend.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/kainos-academy-2026/team4-frontend/issues"
	},
	"homepage": "https://github.com/kainos-academy-2026/team4-frontend#readme",
	"dependencies": {
		"express": "^5.2.1",
		"nunjucks": "^3.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@vitest/ui": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"@types/express": "^5.0.6",
		"@types/node": "^26.1.0",
		"@types/nunjucks": "^3.2.6",
		"vitest": "^4.1.10",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3"
	}
}
