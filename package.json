{
	"name": "team4-frontend",
	"version": "1.0.0",
	"description": "Team4 Frontend",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.json && rsync -a --delete src/views/ dist/views/ && rsync -a --delete public/ dist/public/",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kainos-academy-2026/team4-frontend.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/kainos-academy-2026/team4-frontend/issues"
	},
	"homepage": "https://github.com/kainos-academy-2026/team4-frontend#readme",
	"dependencies": {
		"axios": "^1.18.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"jose": "^5.10.0",
		"nunjucks": "^3.2.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/node": "^26.1.0",
		"@types/nunjucks": "^3.2.6",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"supertest": "^7.2.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
