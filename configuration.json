    "available": [
      "local",
      "dev",
      "staging",
      "production"
    ],
    "ui": {
      "baseUrls": [
        {
          "environment": "local",
          "url": "http://localhost:3000"
        },
        {
          "environment": "dev",
          "url": "https://dev.example.com"
        },
        {
          "environment": "staging",
          "url": "https://staging.example.com"
        },
        {
          "environment": "production",
          "url": "https://example.com"
        }
      ]
    },
    "api": {
      "baseUrls": []
    }
  },
  "utilities": {
    "loggingModule": {
      "enabled": true
    },
    "fileReaders": {
      "enabled": false
    },
    "configuration": {
      "enabled": true
    },
    "asyncWaits": {
      "enabled": false
    },
    "mfa": {
      "enabled": false
    },
    "database": {
      "enabled": true,
