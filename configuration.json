{
  "lastQuestionAnswered": 55,
  "framework": {
    "language": "TypeScript",
    "bddEnabled": true,
    "lifecycle": {
      "globalSetup": false,
      "globalTeardown": false
    }
  },
  "testTypes": {
    "ui": {
      "enabled": true
    },
    "api": {
      "enabled": true
    },
